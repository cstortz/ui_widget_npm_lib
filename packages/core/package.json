{
  "name": "@cstortz/widget-system",
  "version": "0.0.1",
  "description": "Framework-agnostic widget layout core — pure TypeScript, zero dependencies",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && tsc -p tsconfig.test.json && node --test dist-test/**/*.test.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist dist-test"
  },
  "devDependencies": {
    "@types/node": "^22.10.5"
  },
  "keywords": ["widget", "workspace", "layout", "typescript"],
  "license": "AGPL-3.0-or-later",
  "publishConfig": {
    "access": "public"
  }
}
