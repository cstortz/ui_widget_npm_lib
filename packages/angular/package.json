{
  "name": "@ncs_software/widget-system-angular",
  "version": "1.2.2",
  "description": "Angular 17+ components and services for @ncs_software/widget-system",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/fesm2022/ncs_software-widget-system-angular.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "test": "npm run build -w @ncs_software/widget-system && npm run build -w @ncs_software/widget-system-angular && vitest run",
    "lint": "ng-packagr -p ng-package.json --help > /dev/null",
    "clean": "rm -rf dist out-tsc"
  },
  "peerDependencies": {
    "@angular/cdk": ">=17",
    "@angular/common": ">=17",
    "@angular/core": ">=17",
    "@angular/material": ">=17",
    "@ncs_software/widget-system": "*",
    "rxjs": ">=7.8.0"
  },
  "dependencies": {
    "@ncs_software/widget-system": "*",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/animations": "^19.2.0",
    "@angular/cdk": "^19.2.0",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/compiler-cli": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/material": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "jsdom": "^25.0.1",
    "ng-packagr": "^19.2.0",
    "rxjs": "^7.8.1",
    "vitest": "^3.0.5",
    "zone.js": "^0.15.0"
  },
  "keywords": [
    "angular",
    "widget",
    "workspace"
  ],
  "license": "AGPL-3.0-or-later",
  "publishConfig": {
    "access": "public"
  }
}
